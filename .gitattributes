# ==============================================================================
# .gitattributes - Git Line Ending and Binary Handling Configuration
# ==============================================================================
# This file normalizes line endings across platforms and configures Git LFS
# for binary files. All text files are stored with LF in the repository and
# checked out with LF on all platforms (including Windows).
#
# NX Monorepo Setup:
#   - Package manager: Yarn 4 (Yarn Berry)
#   - Build tool: NX 21 with TypeScript
#   - Test framework: Vitest
#   - Language: TypeScript
#

# ==============================================================================
# 1. GLOBAL DEFAULT - Text with LF line endings
# ==============================================================================
# Apply to all files by default: treat as text and normalize to LF
*                                     text=auto eol=lf

# ==============================================================================
# 2. SOURCE CODE - TypeScript/JavaScript/Node
# ==============================================================================
*.ts                                  text eol=lf
*.tsx                                 text eol=lf
*.js                                  text eol=lf
*.jsx                                 text eol=lf
*.mjs                                 text eol=lf
*.cjs                                 text eol=lf

# ==============================================================================
# 3. CONFIG FILES
# ==============================================================================
# JSON configuration files
*.json                                text eol=lf
.babelrc                              text eol=lf
.eslintrc*                            text eol=lf
.prettierrc*                          text eol=lf
.prettierignore                       text eol=lf
tsconfig*.json                        text eol=lf
jest.config.*                         text eol=lf
vitest.config.*                       text eol=lf
nx.json                               text eol=lf

# YAML configuration files
*.yml                                 text eol=lf
*.yaml                                text eol=lf
.github/**/*.yml                      text eol=lf
.github/**/*.yaml                     text eol=lf
.husky/**/*                           text eol=lf
.yarnrc*                              text eol=lf

# Shell/Bash scripts
*.sh                                  text eol=lf
*.bash                                text eol=lf
*.zsh                                 text eol=lf
scripts/**                            text eol=lf

# Environment and configuration
.env                                  text eol=lf
.env.*                                text eol=lf
.editorconfig                         text eol=lf
.gitignore                            text eol=lf
.gitattributes                        text eol=lf
.npmrc                                text eol=lf

# ==============================================================================
# 4. DOCUMENTATION
# ==============================================================================
*.md                                  text eol=lf
*.markdown                            text eol=lf
*.mdx                                 text eol=lf
*.txt                                 text eol=lf
LICENSE                               text eol=lf
README                                text eol=lf

# ==============================================================================
# 5. PACKAGE MANAGEMENT
# ==============================================================================
package.json                          text eol=lf
package-lock.json                     text eol=lf
yarn.lock                             text eol=lf
pnpm-lock.yaml                        text eol=lf

# ==============================================================================
# 6. BINARY FILES - Never handle as text
# ==============================================================================
# Compiled/executable binaries
*.o                                   -text
*.a                                   -text
*.so                                  -text
*.dylib                               -text
*.dll                                 -text
*.exe                                 -text
*.exe.a                               -text
*.bin                                 -text

# Node modules and build artifacts (typically contain mixed binary/text)
node_modules/**                       -text
.yarn/**                              -text
build/**                              -text
dist/**                               -text
coverage/**                           -text
.turbo/**                             -text

# ==============================================================================
# 7. GIT LFS - Track large binary and media files
# ==============================================================================

# Images
*.png                                 filter=lfs diff=lfs merge=lfs -text
*.jpg                                 filter=lfs diff=lfs merge=lfs -text
*.jpeg                                filter=lfs diff=lfs merge=lfs -text
*.gif                                 filter=lfs diff=lfs merge=lfs -text
*.webp                                filter=lfs diff=lfs merge=lfs -text
*.ico                                 filter=lfs diff=lfs merge=lfs -text
*.svg                                 filter=lfs diff=lfs merge=lfs -text
*.tiff                                filter=lfs diff=lfs merge=lfs -text
*.bmp                                 filter=lfs diff=lfs merge=lfs -text

# Fonts
*.woff                                filter=lfs diff=lfs merge=lfs -text
*.woff2                               filter=lfs diff=lfs merge=lfs -text
*.ttf                                 filter=lfs diff=lfs merge=lfs -text
*.otf                                 filter=lfs diff=lfs merge=lfs -text
*.eot                                 filter=lfs diff=lfs merge=lfs -text

# Archives
*.zip                                 filter=lfs diff=lfs merge=lfs -text
*.tar                                 filter=lfs diff=lfs merge=lfs -text
*.gz                                  filter=lfs diff=lfs merge=lfs -text
*.tgz                                 filter=lfs diff=lfs merge=lfs -text
*.bz2                                 filter=lfs diff=lfs merge=lfs -text
*.7z                                  filter=lfs diff=lfs merge=lfs -text
*.rar                                 filter=lfs diff=lfs merge=lfs -text

# Documents and media
*.pdf                                 filter=lfs diff=lfs merge=lfs -text
*.mp4                                 filter=lfs diff=lfs merge=lfs -text
*.mp3                                 filter=lfs diff=lfs merge=lfs -text
*.mov                                 filter=lfs diff=lfs merge=lfs -text
*.avi                                 filter=lfs diff=lfs merge=lfs -text
*.wav                                 filter=lfs diff=lfs merge=lfs -text
*.flv                                 filter=lfs diff=lfs merge=lfs -text

# ==============================================================================
# 8. GITHUB LINGUIST OVERRIDES
# ==============================================================================
# Exclude build output and dependencies from language statistics

# Build artifacts
build/**                              linguist-generated=true
dist/**                               linguist-generated=true
coverage/**                           linguist-generated=true
*.d.ts                                linguist-generated=true
*.map                                 linguist-generated=true

# Dependencies (vendored code)
node_modules/**                       linguist-vendored=true
.yarn/**                              linguist-vendored=true

# NX and tool caches
.turbo/**                             linguist-generated=true
.nx/**                                linguist-generated=true

# ==============================================================================
# End of .gitattributes
# ==============================================================================
