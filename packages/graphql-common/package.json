{
	"name": "@pawells/graphql-common",
	"displayName": "@pawells/graphql-common",
	"version": "2.0.0",
	"description": "Framework-agnostic shared GraphQL primitive types and utilities",
	"type": "module",
	"main": "./build/index.js",
	"types": "./build/index.d.ts",
	"exports": {
		".": {
			"types": "./build/index.d.ts",
			"require": "./build/index.js",
			"import": "./build/index.js"
		}
	},
	"scripts": {
		"build": "tsc --project tsconfig.build.json",
		"typecheck": "tsc --noEmit",
		"lint": "eslint src/",
		"lint:fix": "eslint src/ --fix",
		"test": "vitest run",
		"test:coverage": "vitest run --coverage",
		"pipeline": "yarn typecheck && yarn test && yarn build"
	},
	"dependencies": {
		"async-mutex": ">=0.4.0",
		"graphql-subscriptions": ">=2.0.0",
		"graphql-type-json": ">=0.3.0"
	},
	"peerDependencies": {
		"@apollo/client": ">=3.0.0",
		"graphql": ">=16.0.0"
	},
	"devDependencies": {
		"@apollo/client": "^3.11.8",
		"@types/node": "^20.18.14",
		"async-mutex": "^0.5.0",
		"graphql": "^16.13.2",
		"graphql-subscriptions": "^3.0.0",
		"graphql-type-json": "^0.3.2",
		"typescript": "^6.0.2",
		"vitest": "^4.1.2"
	},
	"engines": {
		"node": ">=22.0.0"
	},
	"packageManager": "yarn@4.12.0",
	"author": "Aaron Wells <69355326+PhillipAWells@users.noreply.github.com>",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/PhillipAWells/graphql"
	},
	"files": [
		"build/",
		"README.md",
		"LICENSE"
	],
	"publishConfig": {
		"access": "public"
	}
}
