{
  "name": "@pawells/graphql-common",
  "displayName": "@pawells/graphql-common",
  "version": "2.1.3",
  "description": "Framework-agnostic shared GraphQL primitive types and utilities",
  "keywords": [
    "graphql",
    "typescript",
    "types",
    "utilities",
    "relay",
    "pagination",
    "connection",
    "cursor",
    "pageinfo",
    "scalars"
  ],
  "type": "module",
  "main": "./build/index.js",
  "types": "./build/index.d.ts",
  "exports": {
    ".": {
      "types": "./build/index.d.ts",
      "import": "./build/index.js"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "pipeline": "yarn typecheck && yarn lint && yarn test && yarn build"
  },
  "dependencies": {
    "async-mutex": "^0.5.0",
    "graphql-subscriptions": "^3.0.0",
    "graphql-type-json": "^0.3.2"
  },
  "peerDependencies": {
    "@apollo/client": ">=3.0.0",
    "graphql": ">=16.0.0",
    "rxjs": ">=7.0.0"
  },
  "devDependencies": {
    "@apollo/client": "^4.1.9",
    "@types/node": "^25.6.0",
    "graphql": "^16.14.0",
    "rxjs": "^7.8.2",
    "typescript": "~6.0.3",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "yarn@4.12.0",
  "author": "Aaron Wells <69355326+PhillipAWells@users.noreply.github.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/PhillipAWells/graphql"
  },
  "files": [
    "build/",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  }
}
