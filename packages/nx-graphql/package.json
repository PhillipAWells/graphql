{
  "name": "@pawells/nx-graphql",
  "displayName": "@pawells/nx-graphql",
  "version": "2.1.5",
  "description": "NX executors for GraphQL schema generation and code generation",
  "keywords": [
    "nx",
    "nrwl",
    "graphql",
    "codegen",
    "schema",
    "typescript",
    "executors",
    "monorepo",
    "plugin",
    "code-generation"
  ],
  "main": "./build/index.js",
  "types": "./build/index.d.ts",
  "exports": {
    ".": {
      "types": "./build/index.d.ts",
      "require": "./build/index.js"
    },
    "./package.json": "./package.json"
  },
  "executors": "./build/executors.json",
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rimraf build",
    "pipeline": "yarn typecheck && yarn lint && yarn test && yarn build"
  },
  "dependencies": {
    "@graphql-codegen/cli": "^7.0.0",
    "@nestjs/common": "^11.1.19",
    "@nestjs/core": "^11.1.19",
    "@nestjs/graphql": "^13.3.0",
    "@nx/devkit": "^22.7.2",
    "graphql": "^16.13.2",
    "reflect-metadata": "^0.2.2"
  },
  "peerDependencies": {
    "@pawells/graphql-codegen-ts": "*",
    "nx": ">=21.0.0",
    "rxjs": ">=7.0.0"
  },
  "peerDependenciesMeta": {
    "@pawells/graphql-codegen-ts": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "nx": "^22.7.2",
    "rxjs": "^7.8.2",
    "typescript": "~6.0.3",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "yarn@4.12.0",
  "author": "Aaron Wells <69355326+PhillipAWells@users.noreply.github.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/PhillipAWells/graphql"
  },
  "files": [
    "build/",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  }
}
