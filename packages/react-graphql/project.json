{
	"name": "react-graphql",
	"$schema": "../../node_modules/nx/schemas/project-schema.json",
	"sourceRoot": "packages/react-graphql/src",
	"projectType": "library",
	"targets": {
		"build": {
			"executor": "@nx/js:tsc",
			"options": {
				"main": "{projectRoot}/src/index.ts",
				"outputPath": "{projectRoot}/build",
				"tsConfig": "{projectRoot}/tsconfig.build.json",
				"rootDir": "{projectRoot}/src",
				"assets": [
					{ "input": "{projectRoot}", "glob": "README.md", "output": "." },
					{ "input": "{projectRoot}", "glob": "LICENSE", "output": "." }
				],
				"updateBuildableProjectDepsInPackageJson": true
			},
			"outputs": ["{projectRoot}/build"]
		},
		"typecheck": {
			"executor": "nx:run-commands",
			"outputs": [],
			"options": {
				"command": "tsc --noEmit",
				"cwd": "{projectRoot}"
			}
		},
		"lint": {
			"executor": "@nx/eslint:lint",
			"outputs": [
				"{options.outputFile}"
			],
			"options": {
				"lintFilePatterns": [
					"{projectRoot}/src/**/*.ts",
					"{projectRoot}/src/**/*.tsx"
				]
			}
		},
		"test": {
			"executor": "nx:run-commands",
			"options": {
				"command": "vitest run",
				"cwd": "{projectRoot}"
			}
		},
		"test:coverage": {
			"executor": "nx:run-commands",
			"options": {
				"command": "vitest run --coverage",
				"cwd": "{projectRoot}"
			}
		},
		"clean": {
			"executor": "nx:run-commands",
			"options": {
				"command": "rimraf build",
				"cwd": "{projectRoot}"
			}
		}
	}
}
